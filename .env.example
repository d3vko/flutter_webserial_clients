# Puerto publicado en el host (contenedor nginx escucha en 8090)
HOST_PORT=8090

# ---------------------------------------------------------------------------
# API compartida: wardriving (/tsim7000g, /tsim7600hg) + marauder (/pwnterrey-marauder)
# Dejar vacío = serial y export CSV local sin login ni upload.
# Tras cambiar estos valores, reconstruir: podman-compose up --build
# ---------------------------------------------------------------------------
WARDRIVE_LOGIN_URL=https://api.example.com/v1/auth/login/
WARDRIVE_REGISTER_URL=https://api.example.com/v1/auth/register/
WARDRIVE_RESET_URL=https://api.example.com/v1/auth/password/reset/
WARDRIVE_UPLOAD_URL=https://api.example.com/v1/files-uploaded/
WARDRIVE_TOKEN_REFRESH_URL=https://api.example.com/v1/auth/token/refresh/

# ---------------------------------------------------------------------------
# device_source por app: ver docs/DEVICE_SOURCES.md
# (valores fijos en lib/core/config/device_profile.dart, no son env vars)
# ---------------------------------------------------------------------------
